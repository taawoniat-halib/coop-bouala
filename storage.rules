rules_version = '2';

// قواعد أمان Firebase Storage — لم تكن منشورة سابقاً (firebase.json لم يكن
// يشير إلى أي ملف قواعد لـ Storage)، مما يعني أن التخزين كان يعمل بالقواعد
// الافتراضية غير المُراجَعة. هذا الملف يقصر الوصول على المستخدمين الموثقين
// فقط، ويحصر الكتابة على مجلد شعار التعاونية (يرفعه المدير من صفحة الإعدادات).
service firebase.storage {
  match /b/{bucket}/o {
    match /logos/{allPaths=**} {
      allow read: if true; // الشعار يُعرض في الواجهة للجميع، بمن فيهم زوار صفحة تسجيل الدخول
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
